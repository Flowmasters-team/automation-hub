        {"role": "user", "content": "Хочу поменять окно"},
        {"role": "user", "content": "Одно окно на кухне, не знаю размеры"},
        {"role": "user", "content": "Кирпичный дом, 2 этаж"}
      ],
      "expected_final_state": "dimensions",
      "expected_fields": {"work_type": "замена окон", "quantity": "1"}
