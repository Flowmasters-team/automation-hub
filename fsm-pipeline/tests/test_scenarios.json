{
  "windows_company": [
    {
      "name": "Happy path — замена окон",
      "messages": [
        {"role": "user", "content": "Здравствуйте, хочу заменить окна"},
        {"role": "user", "content": "Двухкомнатная квартира, панельный дом, 5 этаж"},
        {"role": "user", "content": "3 окна стандартных, двухкамерный стеклопакет, белый профиль"},
        {"role": "user", "content": "Ок, сколько примерно?"},
        {"role": "user", "content": "Нормально, давайте замер"},
        {"role": "user", "content": "Иван, +7-900-123-45-67, ул. Ленина 15, завтра в 14:00"}
      ],
      "expected_final_state": "completed",
      "expected_fields": {"work_type": "замена окон", "client_name": "Иван"}
    },
    {
      "name": "Возражение 'дорого'",
      "messages": [
        {"role": "user", "content": "Нужно остекление балкона"},
        {"role": "user", "content": "Балкон 3 метра, хрущёвка, 4 этаж"},
        {"role": "user", "content": "Холодное остекление, алюминий"},
        {"role": "user", "content": "Дорого, у конкурентов дешевле"}
